# Server
NODE_ENV=development
PORT=5000

# MySQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=invoice_crm

# JWT (authentication)
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Public invoice view
INVOICE_PUBLIC_TOKEN_SECRET=your_invoice_public_view_secret
PUBLIC_APP_URL=http://localhost:5173

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173

# Company details (PDF invoices)
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=123 Business Street, Colombo, Sri Lanka
COMPANY_PHONE=+94 11 234 5678
COMPANY_EMAIL=billing@yourcompany.lk
COMPANY_WEBSITE=https://yourcompany.lk
COMPANY_LOGO_PATH=
PAYMENT_INSTRUCTIONS=Please transfer the total amount within the due date. Use the invoice number as payment reference.

# Bank details (shown on PDF)
COMPANY_BANK_NAME=Commercial Bank of Ceylon
COMPANY_ACCOUNT_NAME=Your Company Name
COMPANY_ACCOUNT_NUMBER=1234567890
COMPANY_BANK_BRANCH=Colombo Main

# SMS gateway (mock by default)
SMS_PROVIDER=notify.lk
SMS_API_KEY=
SMS_SENDER_ID=InvoiceCRM
SMS_ENABLED=false
